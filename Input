# Required imports (these were missing)
from google.colab import files
import cv2
import matplotlib.pyplot as plt

print("📁 Upload a SINGLE image (forged or normal)")
uploaded = files.upload()

image_name = list(uploaded.keys())[0]  # use the first (and only) file
print("Using image_name =", image_name)

# Check if image loaded successfully
img = cv2.imread(image_name)
if img is None:
    print(f"Error: Could not load image '{image_name}'. Check file format (JPG/PNG).")
else:
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    plt.figure(figsize=(8, 6))
    plt.imshow(img_rgb)
    plt.title("Input Image")
    plt.axis('off')
    plt.show()
    print("✅ Image loaded and displayed successfully!")
